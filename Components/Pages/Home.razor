@page "/"

<div class="home-page">

    <!-- HERO -->
    <section class="hero">
        <div class="hero-content">
            <h1>Géomatique <span>Intégrée</span></h1>
            <p>Solutions cartographiques avancées pour l'analyse spatiale et la gestion de données géolocalisées.</p>
            <div class="hero-buttons">
                <a href="/carte" class="btn-hero-primary">🗺️ Voir la carte</a>
                <a href="/contact" class="btn-hero-secondary">📞 Nous contacter</a>
            </div>
        </div>
    </section>

    <!-- SERVICES -->
    <section class="services">
        <h2>Nos Services</h2>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">🗺️</div>
                <h3>Cartographie Interactive</h3>
                <p>Visualisation et analyse de données géospatiales en temps réel avec Carto⁵ MapLibre.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">📊</div>
                <h3>Analyse Spatiale</h3>
                <p>Traitement ETL avancé, intersections spatiales, buffers, analyses temporelles 4D.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">🚛</div>
                <h3>Mode Hors-Ligne</h3>
                <p>Solutions déconnectées pour le travail terrain avec GeoPackage et SQLite natif.</p>
            </div>
        </div>
    </section>

    <!-- CALL TO ACTION -->
    <section class="cta">
        <h2>Prêt à explorer vos données ?</h2>
        <p>Découvrez la puissance de Carto⁵ MapLibre pour votre organisation.</p>
        <a href="/carte" class="btn-hero-primary">🗺️ Lancer la carte</a>
    </section>

</div>