@page "/services"

<PageTitle>Expertise & Services - GisYweb</PageTitle>

<div class="expertise-page">

    <!-- HEADER EXPERTISE -->
    <header class="expertise-hero">
        <h1>Notre <span>Expertise</span></h1>
        <p>De l'acquisition de la donnée sur le terrain jusqu'à sa diffusion dans des tableaux de bord interactifs.</p>
    </header>

    <!-- LES 4 PILIERS DE TON EXPERTISE -->
    <section class="expertise-content">

        <!-- Service 1 : Développement Web GIS -->
        <div class="expertise-row">
            <div class="exp-text">
                <div class="exp-icon">💻</div>
                <h2>Développement Web Géospatial</h2>
                <p>Création d'applications cartographiques sur mesure, rapides et sécuritaires.</p>
                <ul>
                    <li>Architecture <strong>Blazor .NET 8</strong> (Server & WebAssembly)</li>
                    <li>Intégration d'API cartographiques (<strong>MapLibre GL</strong>, ArcGIS API)</li>
                    <li>Création de tableaux de bord (Dashboards) analytiques interactifs</li>
                </ul>
            </div>
            <div class="exp-image" style="background: linear-gradient(135deg, #1a3c2a, #2d7a48);">
                <span>💻 Code & Carto</span>
            </div>
        </div>

        <!-- Service 2 : Traitement de données (ETL) -->
        <div class="expertise-row reverse">
            <div class="exp-text">
                <div class="exp-icon">⚙️</div>
                <h2>Traitement ETL & Base de données</h2>
                <p>Automatisation de l'intégration et de la transformation de vos données spatiales.</p>
                <ul>
                    <li>Scripts <strong>Python</strong> (GeoPandas, Shapely)</li>
                    <li>Workflows <strong>FME (Safe Software)</strong></li>
                    <li>Bases de données spatiales (PostGIS, SQLite, GeoPackage)</li>
                </ul>
            </div>
            <div class="exp-image" style="background: linear-gradient(135deg, #6b4c30, #9c7a5c);">
                <span>⚙️ Data Pipeline</span>
            </div>
        </div>

        <!-- Service 3 : Acquisition par Drones -->
        <div class="expertise-row">
            <div class="exp-text">
                <div class="exp-icon">🚁</div>
                <h2>Acquisition par Drones (UAV)</h2>
                <p>Captation aérienne de haute précision pour modélisation et inspection.</p>
                <ul>
                    <li>Orthophotographies haute résolution</li>
                    <li>Modèles Numériques de Terrain (MNT) et de Surface (MNS)</li>
                    <li>Calcul de volumétrie et inspection d'infrastructures</li>
                </ul>
            </div>
            <div class="exp-image" style="background: linear-gradient(135deg, #e6b422, #d4a017);">
                <span>🚁 Photogrammétrie</span>
            </div>
        </div>

    </section>

    <!-- BANDEAU CTA -->
    <section class="expertise-cta">
        <h2>Un projet en tête ?</h2>
        <a href="/contact" class="btn-hero-primary">Parlez-nous de vos besoins</a>
    </section>

</div>