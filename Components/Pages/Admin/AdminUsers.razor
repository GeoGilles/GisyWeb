@page "/Admin/users"
@layout AdminLayout
@using GisyWeb.Infrastructure.AdminDb.Entities
@using GisyWeb.Services
@inject AdminUserService Svc

<div class="container-fluid py-4" style="background-color:#f4f6f8; min-height:100vh;">

    <!-- Titre de la page façon Dashboard -->
    <div class="mb-4">
        <h4 class="mb-0 fw-bold" style="color: #1a222c;"><i class="bi bi-people-fill me-2 text-warning"></i>GESTION DES UTILISATEURS</h4>
        <div class="text-muted small mt-1">Administration des comptes, des rôles système et des directions territoriales (DT).</div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header text-white py-3 d-flex justify-content-between align-items-center" style="background-color: #1a222c;">
            <div class="fw-bold">Répertoire des Utilisateurs</div>
            <button class="btn btn-sm fw-bold" style="background-color: #e6b422; color: #1a222c;" @onclick="NewUser">
                <i class="bi bi-person-plus-fill me-1"></i>Nouvel Utilisateur
            </button>
        </div>

        <div class="card-body bg-white p-4">
            @if (_loading)
            {
                <div class="text-center text-muted py-5">
                    <div class="spinner-border text-warning mb-3" role="status"></div>
                    <div>Chargement des comptes utilisateurs...</div>
                </div>
            }
            else
            {
                <div class="row g-4">
                    <!-- COLONNE GAUCHE (Liste) -->
                    <div class="col-12 col-xl-7">
                        <div class="input-group mb-3 shadow-sm">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                            <input class="form-control border-start-0" placeholder="Filtrer (code, nom, courriel, DT)..." @bind="_filter" @bind:event="oninput" />
                            <button class="btn btn-outline-secondary" @onclick="ClearFilter">Effacer</button>
                        </div>

                        <div class="table-responsive border rounded" style="max-height: 65vh; overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="sticky-top" style="background-color: #f9fafb;">
                                    <tr>
                                        <th class="text-muted small">CODE</th>
                                        <th class="text-muted small">NOM COMPLET</th>
                                        <th class="text-muted small">COURRIEL</th>
                                        <th class="text-muted small">DT</th>
                                        <th class="text-center text-muted small">ACTIF</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var u in FilteredUsers())
                                    {
                                        <tr class="@(_edit?.UserCode == u.UserCode ? "table-active" : "")">
                                            <td class="fw-bold" style="color: #2d7a48;">@u.UserCode</td>
                                            <td class="fw-bold text-dark">@u.FullName</td>
                                            <td class="small">@u.Email</td>
                                            <td><span class="badge border text-dark" style="background-color: #fafaf7;">@u.DtCode</span></td>
                                            <td class="text-center">
                                                @if (u.IsActive == 1)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-x-circle-fill text-muted opacity-25 fs-5"></i>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-secondary py-1" @onclick="() => Edit(u)" title="Modifier">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- COLONNE DROITE (Fiche) -->
                    <div class="col-12 col-xl-5">
                        <div class="card border border-warning shadow-sm sticky-top" style="top: 1.5rem; background-color: #fafaf7;">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 border-bottom pb-2" style="color: #1a222c;">
                                    <i class="bi bi-person-vcard me-2 text-warning"></i>Fiche Utilisateur
                                </h5>

                                @if (_edit == null)
                                {
                                    <div class="text-muted text-center py-5">
                                        <i class="bi bi-cursor fs-1 opacity-25 d-block mb-3"></i>
                                        Sélectionnez un utilisateur à gauche pour modifier son profil.
                                    </div>
                                }
                                else
                                {
                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label small fw-bold text-muted mb-1">USER_CODE</label>
                                            <input class="form-control font-monospace fw-bold" @bind="_edit.UserCode" disabled="@_isExisting" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label small fw-bold text-muted mb-1">USER_GUID</label>
                                            <input class="form-control form-control-sm font-monospace text-muted" @bind="_edit.UserGuid" />
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted mb-1">NOM COMPLET</label>
                                            <input class="form-control fw-bold" @bind="_edit.FullName" placeholder="Prénom Nom" />
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted mb-1">COURRIEL</label>
                                            <input class="form-control" type="email" @bind="_edit.Email" placeholder="nom@exemple.com" />
                                        </div>

                                        <div class="col-12">
                                            <label class="form-label small fw-bold text-muted mb-1">DESCRIPTION / NOTES</label>
                                            <textarea class="form-control" rows="2" @bind="_edit.Description"></textarea>
                                        </div>

                                        <div class="col-6">
                                            <label class="form-label small fw-bold text-muted mb-1">DT_CODE</label>
                                            <input class="form-control font-monospace" @bind="_edit.DtCode" placeholder="ex: 03" />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small fw-bold text-muted mb-1">DT_NAME</label>
                                            <input class="form-control" @bind="_edit.DtName" placeholder="ex: Capitale-Nationale" />
                                        </div>

                                        <div class="col-6">
                                            <label class="form-label small fw-bold text-muted mb-1">SYS_ROLE_CODE</label>
                                            <input class="form-control fw-bold" @bind="_edit.SysRoleCode" />
                                        </div>
                                        <div class="col-6 d-flex align-items-center">
                                            <div class="form-check form-switch mt-4">
                                                <input class="form-check-input" type="checkbox" id="userActiveSwitch" @bind="_activeBool" />
                                                <label class="form-check-label small fw-bold text-dark" for="userActiveSwitch">Compte Actif</label>
                                            </div>
                                        </div>

                                        <div class="col-12 mt-4 pt-3 border-top d-flex gap-2">
                                            <button class="btn text-white flex-grow-1 fw-bold" style="background-color: #2d7a48;" @onclick="Save" disabled="@_saving">
                                                @if (_saving)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                                }
                                                <i class="bi bi-save2 me-1"></i>ENREGISTRER
                                            </button>
                                            <button class="btn btn-outline-secondary fw-bold" @onclick="Cancel" disabled="@_saving">Annuler</button>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(_msg))
                                        {
                                            <div class="col-12 mt-3 alert alert-info border-0 shadow-sm py-2 px-3 small fw-bold mb-0">
                                                <i class="bi bi-info-circle me-2"></i>@_msg
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // LE C# RESTE INTACT
    private bool _loading = true;
    private bool _saving = false;
    private string _filter = "";
    private string _msg = "";

    private List<CartoUser> _users = new();
    private CartoUser? _edit;

    private bool _isExisting = true;
    private bool _activeBool = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _users = await Svc.GetAllUsersAsync();
        _loading = false;
    }

    private IEnumerable<CartoUser> FilteredUsers()
    {
        if (string.IsNullOrWhiteSpace(_filter)) return _users;

        var f = _filter.Trim().ToLowerInvariant();
        return _users.Where(u =>
            (u.UserCode ?? "").ToLowerInvariant().Contains(f) ||
            (u.FullName ?? "").ToLowerInvariant().Contains(f) ||
            (u.Email ?? "").ToLowerInvariant().Contains(f) ||
            (u.DtCode ?? "").ToLowerInvariant().Contains(f) ||
            (u.DtName ?? "").ToLowerInvariant().Contains(f)
        );
    }

    private void ClearFilter() => _filter = "";

    private void Edit(CartoUser u)
    {
        _isExisting = true;
        _edit = new CartoUser
        {
            UserCode = u.UserCode,
            UserGuid = u.UserGuid,
            FullName = u.FullName,
            Email = u.Email,
            Description = u.Description,
            DtCode = u.DtCode,
            DtName = u.DtName,
            IsActive = u.IsActive,
            SysRoleCode = u.SysRoleCode,
            CreatedAt = u.CreatedAt,
            UpdatedAt = u.UpdatedAt
        };
        _activeBool = _edit.IsActive == 1;
        _msg = "";
    }

    private void NewUser()
    {
        _isExisting = false;
        _edit = new CartoUser
        {
            UserCode = "",
            UserGuid = Guid.NewGuid().ToString(),
            FullName = "",
            IsActive = 1,
            SysRoleCode = "USER",
            CreatedAt = DateTime.Now.ToString("s"),
            UpdatedAt = DateTime.Now.ToString("s")
        };
        _activeBool = true;
        _msg = "";
    }

    private void Cancel()
    {
        _edit = null;
        _msg = "";
    }

    private async Task Save()
    {
        if (_edit == null) return;

        if (string.IsNullOrWhiteSpace(_edit.UserCode) || string.IsNullOrWhiteSpace(_edit.FullName))
        {
            _msg = "USER_CODE et FULL_NAME sont requis.";
            return;
        }

        _saving = true;
        try
        {
            _edit.IsActive = _activeBool ? 1 : 0;

            var now = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
            if (string.IsNullOrWhiteSpace(_edit.CreatedAt)) _edit.CreatedAt = now;
            _edit.UpdatedAt = now;

            await Svc.SaveUserAsync(_edit);
            _users = await Svc.GetAllUsersAsync();
            _msg = "Enregistré.";
            _edit = null;
        }
        catch (Exception ex)
        {
            _msg = "Erreur : " + ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}