@page "/carte-3d"

<PageTitle>Portail 3D - GisYweb</PageTitle>

<style>
    /* On cache le footer pour que la carte prenne tout l'espace vers le bas */
    ::deep .gw-footer {
        display: none !important;
    }
</style>

<!-- Le nouvel iFrame ArcGIS officiel, avec nos dimensions plein écran -->
<iframe src="https://arcg.is/1Pq8fb2"
        style="position: fixed; top: 64px; left: 0; width: 100%; height: calc(100vh - 64px); border: none;"
        frameborder="0"
        scrolling="no"
        allowfullscreen>
</iframe>