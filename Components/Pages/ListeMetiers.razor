@page "/liste-metiers"
@rendermode InteractiveServer

<PageTitle>Répertoire des Métiers - GisYweb</PageTitle>

<div class="repertoire-page">

    <!-- HERO & BARRE DE RECHERCHE -->
    <header class="repertoire-hero">
        <h1>Répertoire des <span>Métiers</span></h1>
        <p>Découvrez comment la géomatique transforme plus de 80 professions à travers le monde.</p>

        <!-- BARRE DE RECHERCHE BLAZOR -->
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input type="text"
                   placeholder="Rechercher un métier (ex: Urbaniste, Forêt, Eau...)"
                   @bind="TermeRecherche"
                   @bind:event="oninput" />
        </div>
    </header>

    <!-- GRILLE DES RÉSULTATS -->
    <section class="metiers-container">

        <div class="result-count">
            @MetiersFiltres.Count() métier(s) trouvé(s)
        </div>

        <div class="metiers-grid">
            @foreach (var metier in MetiersFiltres)
            {
                <div class="metier-card">
                    <div class="metier-header">
                        <span class="metier-code">@metier.Code</span>
                        <h3>@metier.Titre</h3>
                    </div>
                    <div class="metier-body">
                        <div class="metier-section">
                            <h4>Description du métier</h4>
                            <p>@metier.Description</p>
                        </div>
                        <div class="metier-section highlight">
                            <h4>🌐 Utilisation de la géomatique</h4>
                            <p>@metier.Utilisation</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!MetiersFiltres.Any())
        {
            <div class="no-results">
                <h3>Aucun métier trouvé pour "@TermeRecherche"</h3>
                <p>Essayez un autre mot-clé.</p>
            </div>
        }

    </section>
</div>

@code {
