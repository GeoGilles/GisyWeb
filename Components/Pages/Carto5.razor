@page "/carto5"

<PageTitle>Plateforme Carto⁵ - GisYweb</PageTitle>

<div class="carto5-page">

    <!-- EN-TÊTE LOGICIEL -->
    <section class="software-hero">
        <div class="software-hero-content">
            <div class="badge">NOUVELLE GÉNÉRATION</div>
            <h1>Plateforme <span>Carto⁵</span></h1>
            <p>Le Système Intégré d'Analyse de Sécurité (SIAS) propulsé par la vitesse de MapLibre GL et la puissance de Blazor.</p>
            <div class="software-actions">
                <a href="/carte" class="btn-hero-primary">🚀 Lancer l'application</a>
            </div>
        </div>
        <div class="software-hero-image">
            <!-- Tu pourras mettre une capture d'écran de ta map ici plus tard -->
            <div class="mockup-placeholder">
                🗺️ Interface Carto⁵
            </div>
        </div>
    </section>

    <!-- CARACTÉRISTIQUES CLÉS -->
    <section class="features">
        <div class="features-header">
            <h2>Conçu pour la performance</h2>
            <p>Une architecture moderne pour des analyses géospatiales sans compromis.</p>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="f-icon">⚡</div>
                <h3>Rendu Vectoriel Ultra-Rapide</h3>
                <p>Oubliez les temps de chargement. MapLibre GL offre une fluidité exceptionnelle même avec des milliers de points.</p>
            </div>

            <div class="feature-card">
                <div class="f-icon">🔌</div>
                <h3>Mode 100% Déconnecté</h3>
                <p>Grâce à SQLite et GeoPackage natif, travaillez sur le terrain sans aucune connexion internet.</p>
            </div>

            <div class="feature-card">
                <div class="f-icon">✏️</div>
                <h3>Édition Avancée</h3>
                <p>Outils de dessin vectoriel (points, lignes, polygones), snapping (accrochage) et topologie intégrés.</p>
            </div>

            <div class="feature-card">
                <div class="f-icon">📊</div>
                <h3>Analyses SIAS</h3>
                <p>Tableaux de bord interactifs, filtres avancés, intersections spatiales et requêtes attributaires complexes.</p>
            </div>
        </div>
    </section>

    <!-- SECTION TECHNIQUE -->
    <section class="tech-stack">
        <h2>Sous le capot</h2>
        <div class="tech-tags">
            <span>.NET 8 Blazor</span>
            <span>MapLibre GL JS</span>
            <span>SQLite / GeoPackage</span>
            <span>ArcGIS Interop</span>
            <span>FME / ETL</span>
        </div>
    </section>

</div>